{
  "name": "echoesofaincrad",
  "version": "1.0.2",
  "description": "Vortex Extension for Echoes of Aincrad",
  "author": "d3Ex22",
  "private": true,
  "main": "./dist/index.js",
  "type": "module",
  "config": {
    "extensionName": "Echoes of Aincrad",
    "issueTracker": "https://github.com/d3Ex22/game-echoesofaincrad/issues"
  },
  "scripts": {
    "copyassets": "copyfiles -f ./src/assets/** ./dist/",
    "build": "npx webpack && npm run copyassets && node createinfojson.js && npm run packplugin",
    "buildcopydev": "npm run build && npm run copyplugin",
    "copyplugin": "node copyplugin.js",
    "copyplugindev": "node copyplugin.js -dev",
    "packplugin": "node packageplugin.js"
  },
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/node": "^18.19.130",
    "copyfiles": "^2.4.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "vortex-api": "Nexus-Mods/vortex-api",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "archiver": "^7.0.1"
  }
}
